{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polymetric.local/contracts/analysis_result.schema.json",
  "title": "PolyMetricAnalysisResult",
  "type": "object",
  "required": [
    "run_id",
    "project_id",
    "commit_hash",
    "branch_name",
    "analyzed_at",
    "parser_version",
    "files",
    "functions",
    "dependencies",
    "hotspots"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "project_id": {
      "type": "string",
      "format": "uuid"
    },
    "commit_hash": {
      "type": "string",
      "minLength": 7
    },
    "branch_name": {
      "type": "string",
      "minLength": 1
    },
    "commit_tag": {
      "type": "string"
    },
    "analyzed_at": {
      "type": "string",
      "format": "date-time"
    },
    "parser_version": {
      "type": "string"
    },
    "grammar_version": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "language"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "language": {
            "type": "string",
            "minLength": 1
          },
          "complexity_score": {
            "type": "number"
          },
          "maintainability_index": {
            "type": "number"
          },
          "dependency_count": {
            "type": "integer",
            "minimum": 0
          },
          "loc": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "functions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "file_path",
          "function_name",
          "cyclomatic_complexity"
        ],
        "properties": {
          "file_path": {
            "type": "string"
          },
          "function_name": {
            "type": "string",
            "minLength": 1
          },
          "start_line": {
            "type": "integer",
            "minimum": 1
          },
          "end_line": {
            "type": "integer",
            "minimum": 1
          },
          "cyclomatic_complexity": {
            "type": "integer",
            "minimum": 0
          },
          "halstead_score": {
            "type": "number"
          },
          "loc": {
            "type": "integer",
            "minimum": 0
          },
          "risk_score": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_path",
          "target_path",
          "dependency_type"
        ],
        "properties": {
          "source_path": {
            "type": "string"
          },
          "target_path": {
            "type": "string"
          },
          "dependency_type": {
            "type": "string",
            "enum": [
              "import",
              "call",
              "inheritance",
              "composition"
            ]
          },
          "source_symbol": {
            "type": "string"
          },
          "target_symbol": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "hotspots": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "file_path",
          "function_name",
          "risk_score",
          "reason",
          "rank"
        ],
        "properties": {
          "file_path": {
            "type": "string"
          },
          "function_name": {
            "type": "string"
          },
          "risk_score": {
            "type": "number"
          },
          "reason": {
            "type": "string"
          },
          "rank": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        },
        "additionalProperties": false
      }
    },
    "extra": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
